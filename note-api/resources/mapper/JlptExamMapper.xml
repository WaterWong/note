<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="org.open.lang.ms.note.api.module.jlpt.JlptExamMapper">

    <select id="historyCount" parameterType="org.open.lang.ms.note.api.module.jlpt.vo.JlptExamCondition" resultType="int">
        select count(1)
        from "jlpt_exam"
        where "create_user_id" = #{createUserId}
          and "level" = #{level}
          and "exam_ym" = #{examYm}
    </select>

</mapper>
