<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="org.open.lang.ms.note.api.module.jlpt.record.JlptExamRecordMapper">

    <select id="listByExamId" parameterType="string" resultType="org.open.lang.ms.note.api.module.jlpt.record.JlptExamRecord">
        select *
        from "jlpt_exam_record"
        where "exam_id" = #{examId}
        order by "section_type", "question_no"
    </select>

    <delete id="deleteByExamId" parameterType="string">
        delete from "jlpt_exam_record"
        where "exam_id" = #{examId}
    </delete>

    <delete id="deleteByCondition" parameterType="org.open.lang.ms.note.api.module.jlpt.vo.JlptExamCondition">
        delete from "jlpt_exam_record"
        where "exam_id" in (
            select "id"
            from "jlpt_exam"
            where "create_user_id" = #{createUserId}
              and "level" = #{level}
              and "exam_ym" = #{examYm}
        )
    </delete>

</mapper>
