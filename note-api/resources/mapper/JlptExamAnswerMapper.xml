<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="org.open.lang.ms.note.api.module.jlpt.answer.JlptExamAnswerMapper">

    <select id="listByCondition" parameterType="org.open.lang.ms.note.api.module.jlpt.vo.JlptExamCondition" resultType="org.open.lang.ms.note.api.module.jlpt.answer.JlptExamAnswer">
        select *
        from "jlpt_exam_answer"
        where "create_user_id" = #{createUserId}
          and "level" = #{level}
          and "exam_ym" = #{examYm}
        order by "section_type", "question_no"
    </select>

    <delete id="deleteByCondition" parameterType="org.open.lang.ms.note.api.module.jlpt.vo.JlptExamCondition">
        delete from "jlpt_exam_answer"
        where "create_user_id" = #{createUserId}
          and "level" = #{level}
          and "exam_ym" = #{examYm}
    </delete>

</mapper>
